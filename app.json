{
  "expo": {
    "name": "Pro-Builders Insurance Agency",
    "slug": "insureprobuilders",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/pbialogo.png",
    "scheme": "insureprobuilders",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.johncontractorsischool.insureprobuilders",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/pbialogo.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.johncontractorsischool.insureprobuilders"
    },
    "web": {
      "output": "single",
      "favicon": "./assets/images/pbialogo.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/pbialogo.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d4d7849a-ade7-4fee-bb49-2c38ec0a3cff"
      }
    }
  }
}
